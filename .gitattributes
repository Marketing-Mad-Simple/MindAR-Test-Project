# Normalize line endings to LF for all text files
* text=auto eol=lf

# ── Web source — explicitly text ───────────────────────
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# ── Binary assets — no diff, no CRLF conversion ────────
# 3D models
*.glb   binary
*.gltf  binary

# MindAR compiled image targets
*.mind  binary

# Video
*.mp4   binary
*.webm  binary

# HLS video segments (.ts here is MPEG-TS, not TypeScript)
# If TypeScript files are added later, add: *.ts text eol=lf
# above this rule to override it for source files.
video-ar/**/*.ts binary

# Images
*.jpg   binary
*.jpeg  binary
*.png   binary
*.webp  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
